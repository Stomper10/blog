---
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import type { Lang } from '../../i18n/ui';
import { getPosts, postUrl, useTranslations, type PostCollection } from '../../i18n/utils';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../FormattedDate.astro';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// 노트·프로젝트·일상 글을 한데 모아 최신순 5개를 보여준다.
const sections: PostCollection[] = ['notes', 'projects', 'writing'];
const recent = (
	await Promise.all(
		sections.map(async (collection) =>
			(await getPosts(collection, lang)).map((post) => ({ collection, post })),
		),
	)
)
	.flat()
	.sort((a, b) => b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf())
	.slice(0, 5);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION[lang]}>
	<section class="intro">
		{
			lang === 'ko' ? (
				<>
					<h1>안녕하세요 👋</h1>
					<p>
						{/* TODO: 자기소개로 교체 */}
						연구하는 사람입니다. 이곳은 논문과 프로젝트, 그리고 야구·영화·여행·운동에 대한
						기록이 함께 사는 디지털 홈입니다.
					</p>
				</>
			) : (
				<>
					<h1>Hi, I'm — 👋</h1>
					<p>
						{/* TODO: replace with your introduction */}
						I'm a researcher. This is my digital home where papers, projects, and writing on
						baseball, movies, travel, and fitness live together.
					</p>
				</>
			)
		}
	</section>

	<section class="recent">
		<h2>{t('home.recent')}</h2>
		<ul>
			{
				recent.map(({ collection, post }) => (
					<li>
						<a href={postUrl(collection, post)}>
							<span class="section-tag">{t(`section.${collection}`)}</span>
							<span class="title">{post.data.title}</span>
							<span class="date">
								<FormattedDate date={post.data.pubDate} />
							</span>
						</a>
					</li>
				))
			}
		</ul>
	</section>
</BaseLayout>

<style>
	.intro {
		padding: var(--space-6) 0 var(--space-8);
	}
	.intro h1 {
		margin-bottom: var(--space-4);
		font-size: var(--text-large-title);
	}
	.intro p {
		max-width: 60ch;
		color: var(--label-secondary);
		font-size: var(--text-headline);
		line-height: var(--leading-relaxed);
		margin: 0;
	}
	.recent {
		margin-top: var(--space-10);
	}
	.recent > h2 {
		font-size: var(--text-footnote);
		font-weight: var(--weight-semibold);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		color: var(--label-tertiary);
		margin-bottom: var(--space-2);
	}
	.recent ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.recent li {
		border-bottom: 1px solid var(--separator);
	}
	.recent a {
		display: grid;
		grid-template-columns: 6rem minmax(0, 1fr) auto;
		gap: var(--space-4);
		align-items: baseline;
		padding: var(--space-4) 0;
		text-decoration: none;
	}
	.recent a:hover {
		opacity: 1;
	}
	.section-tag {
		flex-shrink: 0;
		font-size: var(--text-caption-1);
		font-weight: var(--weight-medium);
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--color-accent);
		white-space: nowrap;
	}
	.title {
		min-width: 0;
		color: var(--label-primary);
		font-weight: var(--weight-medium);
	}
	.recent a:hover .title {
		color: var(--color-accent);
	}
	.date {
		margin-left: auto;
		flex-shrink: 0;
		font-size: var(--text-footnote);
		font-variant-numeric: tabular-nums;
		color: var(--label-tertiary);
		white-space: nowrap;
	}
	@media (max-width: 600px) {
		.recent a {
			grid-template-columns: 1fr auto;
		}
		.section-tag {
			grid-column: 1 / -1;
		}
	}
</style>
