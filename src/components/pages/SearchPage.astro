---
import Search from 'astro-pagefind/components/Search.astro';
import { SITE_TITLE } from '../../consts';
import type { Lang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Pagefind는 <html lang>을 보고 언어별 인덱스를 따로 만들기 때문에
// ko 검색 페이지에선 ko 글만, en 페이지에선 en 글만 검색된다.
interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const koTranslations = {
	placeholder: '검색어를 입력하세요',
	clear_search: '지우기',
	load_more: '더 보기',
	zero_results: '"[SEARCH_TERM]"에 대한 결과가 없습니다',
	many_results: '"[SEARCH_TERM]" 검색 결과 [COUNT]건',
	one_result: '"[SEARCH_TERM]" 검색 결과 [COUNT]건',
	searching: '검색 중…',
};
---

<BaseLayout title={`${t('nav.search')} | ${SITE_TITLE}`} description={t('nav.search')}>
	<h1>{t('nav.search')}</h1>
	<Search
		id="search"
		className="pagefind-ui"
		uiOptions={{
			showImages: false,
			translations: lang === 'ko' ? koTranslations : {},
		}}
	/>
</BaseLayout>

<style is:global>
	/* Pagefind UI가 우리 디자인 토큰(라이트/다크)을 따라가도록 매핑한다.
	   클래스를 두 번 적어 Pagefind 기본 CSS(.pagefind-ui)보다 우선순위를 높인다. */
	.pagefind-ui.pagefind-ui {
		--pagefind-ui-primary: var(--color-accent);
		--pagefind-ui-text: var(--label-primary);
		--pagefind-ui-background: var(--bg-primary);
		--pagefind-ui-border: var(--separator);
		--pagefind-ui-tag: var(--fill-tertiary);
		--pagefind-ui-border-width: 1px;
		--pagefind-ui-border-radius: var(--radius-md);
		--pagefind-ui-font: var(--font-sans);
	}
	.pagefind-ui .pagefind-ui__search-input {
		color: var(--label-primary);
		background-color: var(--fill-quaternary);
	}
	.pagefind-ui .pagefind-ui__result {
		border-top: 1px solid var(--separator);
	}
	.pagefind-ui .pagefind-ui__result-link {
		color: var(--label-primary);
	}
	.pagefind-ui .pagefind-ui__result-excerpt {
		color: var(--label-secondary);
	}
	.pagefind-ui mark {
		background-color: color-mix(in srgb, var(--color-accent) 22%, transparent);
		color: var(--label-primary);
	}
</style>
