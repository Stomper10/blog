---
import { SITE_TITLE } from '../../consts';
import type { Lang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<BaseLayout title={`${t('nav.cv')} | ${SITE_TITLE}`} description={t('nav.cv')}>
	{
		lang === 'ko' ? (
			<>
				<h1>이력서</h1>
				{/* TODO: 실제 이력으로 교체. PDF를 public/에 두고 링크해도 된다. */}
				<section>
					<h2>학력</h2>
					<p>—</p>
				</section>
				<section>
					<h2>경력</h2>
					<p>—</p>
				</section>
				<section>
					<h2>논문</h2>
					<p>
						<a href="/research/">연구 페이지</a>에서 확인할 수 있습니다.
					</p>
				</section>
			</>
		) : (
			<>
				<h1>Curriculum Vitae</h1>
				{/* TODO: replace with your actual CV. You can also link a PDF placed in public/. */}
				<section>
					<h2>Education</h2>
					<p>—</p>
				</section>
				<section>
					<h2>Experience</h2>
					<p>—</p>
				</section>
				<section>
					<h2>Publications</h2>
					<p>
						See the <a href="/en/research/">research page</a>.
					</p>
				</section>
			</>
		)
	}
</BaseLayout>
