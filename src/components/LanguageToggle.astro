---
import { languages, otherLang } from '../i18n/ui';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
	/**
	 * 반대 언어 버전의 URL.
	 * 글 페이지는 translationKey로 찾은 짝의 URL을 내려주고,
	 * 생략하면 /en 프리픽스를 토글한 대칭 경로를 쓴다 (인덱스·정적 페이지용).
	 */
	translationUrl?: string;
}

const lang = getLangFromUrl(Astro.url);
const target = otherLang(lang);
const t = useTranslations(lang);

const symmetricPath =
	lang === 'ko'
		? `/en${Astro.url.pathname}`
		: Astro.url.pathname.replace(/^\/en(?=\/|$)/, '') || '/';

const href = Astro.props.translationUrl ?? symmetricPath;
---

<a class="lang-toggle" href={href} aria-label={t('toggle.label')}>
	{languages[target]}
</a>

<style>
	.lang-toggle {
		display: inline-block;
		padding: 0.2em 0.7em;
		border: 1px solid var(--separator);
		border-radius: var(--radius-full);
		font-size: var(--text-caption-1);
		font-weight: var(--weight-medium);
		color: var(--label-secondary);
		text-decoration: none;
		white-space: nowrap;
		transition:
			border-color var(--duration-fast) var(--ease-out),
			color var(--duration-fast) var(--ease-out);
	}
	.lang-toggle:hover {
		border-color: var(--color-accent);
		color: var(--color-accent);
		opacity: 1;
	}
</style>
