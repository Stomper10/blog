---
import { postUrl, type PostCollection, type PostEntry } from '../i18n/utils';
import FormattedDate from './FormattedDate.astro';

interface Props {
	collection: PostCollection;
	posts: PostEntry[];
}

const { collection, posts } = Astro.props;
---

<ul class="post-list">
	{
		posts.map((post) => (
			<li class="feed-item">
				<a class="feed-link" href={postUrl(collection, post)}>
					<span class="feed-date">
						<FormattedDate date={post.data.pubDate} />
					</span>
					<span class="feed-body">
						<span class="feed-title">{post.data.title}</span>
						{post.data.description && <span class="feed-desc">{post.data.description}</span>}
					</span>
					<span class="feed-arrow" aria-hidden="true">→</span>
				</a>
			</li>
		))
	}
</ul>

<style>
	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.feed-item {
		border-bottom: 1px solid var(--separator);
	}
	.feed-link {
		display: grid;
		grid-template-columns: 7.5rem minmax(0, 1fr) auto;
		gap: var(--space-5);
		align-items: baseline;
		padding: var(--space-5) 0;
		text-decoration: none;
		color: inherit;
	}
	.feed-link:hover {
		opacity: 1;
	}
	.feed-date {
		color: var(--label-tertiary);
		font-size: var(--text-footnote);
		font-variant-numeric: tabular-nums;
		white-space: nowrap;
	}
	.feed-body {
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}
	.feed-title {
		color: var(--label-primary);
		font-size: var(--text-title-3);
		font-weight: var(--weight-semibold);
		line-height: var(--leading-snug);
		letter-spacing: -0.012em;
		transition: color var(--duration-fast) var(--ease-out);
	}
	.feed-link:hover .feed-title {
		color: var(--color-accent);
	}
	.feed-desc {
		max-width: min(62ch, 100%);
		color: var(--label-secondary);
		font-size: var(--text-callout);
		line-height: var(--leading-normal);
		overflow-wrap: break-word;
	}
	.feed-arrow {
		color: var(--label-quaternary);
		transition:
			color var(--duration-fast) var(--ease-out),
			transform var(--duration-fast) var(--ease-out);
	}
	.feed-link:hover .feed-arrow {
		color: var(--color-accent);
		transform: translate(2px, -2px);
	}
	@media (max-width: 600px) {
		.feed-link {
			grid-template-columns: minmax(0, 1fr) auto;
		}
		.feed-date {
			grid-column: 1 / -1;
			font-size: var(--text-caption-1);
		}
	}
</style>
