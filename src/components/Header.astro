---
import { SITE_TITLE } from '../consts';
import { getLangFromUrl, localizePath, useTranslations } from '../i18n/utils';
import HeaderLink from './HeaderLink.astro';
import LanguageToggle from './LanguageToggle.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
	/** 글 페이지에서 translationKey로 계산한 반대 언어 URL (LanguageToggle로 전달) */
	translationUrl?: string;
}

const { translationUrl } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navItems = [
	{ href: '/research/', label: t('nav.research') },
	{ href: '/notes/', label: t('nav.notes') },
	{ href: '/projects/', label: t('nav.projects') },
	{ href: '/writing/', label: t('nav.writing') },
	{ href: '/cv/', label: t('nav.cv') },
];
---

<a href="#main-content" class="skip-link" tabindex="0">
	{lang === 'ko' ? '본문으로 건너뛰기' : 'Skip to content'}
</a>
<header class="site-header">
	<nav class="nav-inner">
		<a class="nav-logo" href={localizePath('/', lang)}>{SITE_TITLE}</a>
		<div class="nav-right">
			<div class="nav-links">
				{navItems.map((item) => <HeaderLink href={localizePath(item.href, lang)}>{item.label}</HeaderLink>)}
			</div>
			<div class="nav-actions">
				<a class="icon-link" href={localizePath('/search/', lang)} aria-label={t('nav.search')}>
					<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18" fill="none"
						><path
							stroke="currentColor"
							stroke-linecap="round"
							stroke-width="2"
							d="m21 21-4.35-4.35M17 10.5a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z"
						></path></svg
					>
				</a>
				<ThemeToggle />
				<LanguageToggle translationUrl={translationUrl} />
			</div>
		</div>
	</nav>
</header>

<script is:inline>
	(function () {
		function mountAutoHideHeader() {
			const header = document.querySelector('.site-header');
			if (!(header instanceof HTMLElement) || header.dataset.scrollReady === 'true') return;
			header.dataset.scrollReady = 'true';

			let lastY = window.scrollY;
			let ticking = false;

			const sync = () => {
				const currentY = window.scrollY;
				const delta = currentY - lastY;
				header.classList.toggle('is-scrolled', currentY > 8);

				if (currentY < 24) {
					header.classList.remove('is-hidden');
				} else if (delta > 8 && currentY > 96) {
					header.classList.add('is-hidden');
				} else if (delta < -8) {
					header.classList.remove('is-hidden');
				}

				lastY = currentY;
				ticking = false;
			};

			sync();
			window.addEventListener(
				'scroll',
				() => {
					if (!ticking) {
						window.requestAnimationFrame(sync);
						ticking = true;
					}
				},
				{ passive: true },
			);
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', mountAutoHideHeader, { once: true });
		} else {
			mountAutoHideHeader();
		}
	})();
</script>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 100;
		height: var(--nav-height);
		background-color: var(--bg-primary);
		backdrop-filter: saturate(180%) blur(20px);
		-webkit-backdrop-filter: saturate(180%) blur(20px);
		border-bottom: 1px solid transparent;
		transform: translateY(0);
		transition:
			transform var(--duration-normal) var(--ease-out),
			background-color var(--duration-fast) var(--ease-out),
			border-color var(--duration-fast) var(--ease-out);
		will-change: transform;
	}
	.site-header.is-scrolled {
		background-color: color-mix(in srgb, var(--bg-primary) 86%, transparent);
		border-bottom-color: var(--separator);
	}
	.site-header.is-hidden {
		transform: translateY(calc(-1 * var(--nav-height)));
	}
	.nav-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-4);
		max-width: var(--max-width-wide);
		margin: 0 auto;
		padding: 0 var(--space-6);
		height: 100%;
	}
	.nav-logo {
		font-size: var(--text-headline);
		font-weight: var(--weight-semibold);
		color: var(--label-primary);
		letter-spacing: var(--tracking-tight);
		white-space: nowrap;
	}
	.nav-logo:hover {
		opacity: 0.7;
	}
	.nav-right {
		display: flex;
		align-items: center;
		gap: var(--space-5);
	}
	.nav-links {
		display: flex;
		align-items: center;
		gap: var(--space-4);
	}
	.nav-links :global(a) {
		font-size: var(--text-subheadline);
		font-weight: var(--weight-medium);
		color: var(--label-secondary);
	}
	.nav-links :global(a:hover) {
		color: var(--label-primary);
		opacity: 1;
	}
	.nav-links :global(a.active) {
		color: var(--label-primary);
		text-decoration: none;
	}
	.nav-actions {
		display: flex;
		align-items: center;
		gap: var(--space-2);
	}
	.icon-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		color: var(--label-secondary);
	}
	.icon-link:hover {
		color: var(--label-primary);
		opacity: 1;
	}
	@media (max-width: 720px) {
		.nav-inner {
			padding: 0 var(--space-4);
		}
		.nav-right {
			gap: var(--space-3);
		}
		.nav-links {
			gap: var(--space-3);
		}
		.nav-links :global(a) {
			font-size: var(--text-footnote);
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.site-header {
			transition: none;
		}
	}
</style>
